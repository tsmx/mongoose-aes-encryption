{
  "name": "mongoose-aes-encryption",
  "version": "1.0.1",
  "description": "Mongoose plugin adding AES-256-GCM encryption at rest to schemas. Supports sub-schemas and inline nested sub-documents.",
  "main": "mongoose-aes-encryption.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "jest",
    "test-coverage": "jest --coverage",
    "coveralls": "jest --coverage && coveralls < coverage/lcov.info"
  },
  "author": "tsmx <dev@tsmx.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsmx/mongoose-aes-encryption.git"
  },
  "keywords": [
    "mongoose",
    "MongoDB",
    "plugin",
    "encryption",
    "decryption",
    "string",
    "number",
    "date",
    "boolean",
    "AES",
    "AES-256-GCM",
    "AES-256-CBC",
    "encryption-at-rest",
    "sub-schemas"
  ],
  "dependencies": {
    "@tsmx/string-crypto": "^2.0.0",
    "mongoose": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "eslint": "^9.8.0",
    "eslint-plugin-jest": "^28.8.0",
    "jest": "^29.5.0",
    "mongodb-memory-server": "^11.0.0"
  }
}
